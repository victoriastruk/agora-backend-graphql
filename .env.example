# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/hub

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-token-key-here-minimum-16-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-here-minimum-16-chars
ROOM_TOKEN_SECRET=your-super-secret-room-token-key-here-minimum-16-chars

# JWT Token TTL (Time To Live)
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000
ROOM_TOKEN_TTL_SEC=120

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
