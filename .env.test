# Test environment configuration
NODE_ENV=test
PORT=4001

# SQLite database for testing (in-memory or file-based)
DATABASE_URL=sqlite::memory:

# Mock Redis URL for testing
REDIS_URL=redis://localhost:6379

# Test JWT secrets (can be any strings for testing)
JWT_ACCESS_SECRET=test_access_secret_key_minimum_16_chars
JWT_REFRESH_SECRET=test_refresh_secret_key_minimum_16_chars
ROOM_TOKEN_SECRET=test_room_token_secret_key_minimum_16_chars

# CORS origin for tests
CORS_ORIGIN=http://localhost:3000
