{
  "name": "reddit-client-back",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/app.ts",
    "start:docker": "./scripts/start.sh",
    "stop:docker": "./scripts/stop.sh",
    "build": "bun build --target=bun src/app.ts --outdir=dist",
    "format": "prettier --write src/",
    "format:imports": "prettier --write src/ --plugin=@trivago/prettier-plugin-sort-imports",
    "lint": "oxlint src/",
    "lint:aware": "oxlint --type-aware",
    "lint:fix": "oxlint --fix && npm run format:imports",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepare": "lefthook install",
    "preinstall": "npx only-allow bun",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seeds/seed.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/graphql-yoga": "^1.4.0",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@types/node": "^24.9.2",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "elysia": "^1.4.13",
    "ioredis": "^5.8.2",
    "nanoid": "^5.1.6",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "postgres": "^3.4.7",
    "ulid": "^3.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/bun": "^1.3.1",
    "bun-types": "^1.3.1",
    "drizzle-kit": "^0.31.6",
    "lefthook": "^2.0.2",
    "oxlint": "^1.25.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "vitest": "^4.0.6"
  },
  "module": "src/index.js"
}
