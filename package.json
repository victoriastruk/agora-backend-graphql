{
  "name": "reddit-client-back",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/app.ts",
    "start:docker": "./scripts/start.sh",
    "stop:docker": "./scripts/stop.sh",
    "build": "bun build --target=bun src/app.ts --outdir=dist",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint src/",
    "lint:aware": "oxlint --type-aware",
    "lint:fix": "oxlint --fix src/ && bun run fmt",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepare": "lefthook install",
    "preinstall": "npx only-allow bun",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seeds/seed.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/graphql-yoga": "^1.4.0",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.11",
    "@elysiajs/swagger": "^1.3.1",
    "@graphql-tools/schema": "^10.0.30",
    "@types/node": "^25.0.2",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.19",
    "graphql-subscriptions": "^3.0.0",
    "ioredis": "^5.8.2",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.7",
    "ulid": "^3.0.2",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@types/bun": "^1.3.4",
    "bun-types": "^1.3.4",
    "drizzle-kit": "^0.31.8",
    "lefthook": "^2.0.12",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.32.0",
    "oxlint-tsgolint": "^0.9.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.15"
  },
  "module": "src/index.js"
}
